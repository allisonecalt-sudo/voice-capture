{
  "name": "voice-capture",
  "version": "0.1.0",
  "description": "Allison's voice → Gemini transcript → copy tool. Single screen: record, transcribe, copy. No backend, key in localStorage only.",
  "private": true,
  "scripts": {
    "build": "tsc",
    "lint": "eslint app.ts wav.ts gemini.ts supabase.ts history.ts auth.ts push.ts --ext .ts",
    "format": "prettier --write \"**/*.{ts,html,css,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,html,css,json,md}\" --ignore-path .prettierignore",
    "test": "playwright test",
    "test:ci": "playwright test",
    "serve": "serve -l 3100 .",
    "rasterize-icons": "node scripts/rasterize-icons.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.1.0",
    "prettier": "^3.3.0",
    "serve": "^14.2.0",
    "typescript": "^5.6.0"
  }
}
